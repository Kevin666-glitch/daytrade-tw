{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "www",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }]
    },
    {
      "source": "/icon.svg",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
